# mobile-claude config
# Source this in scripts: source ~/mobile-claude/scripts/config.env
# Also source your OpenRC file: source ~/openrc.sh

# Instance config
OVH_SNAPSHOT_ID="SNAPSHOT"
OVH_FLAVOR_ID="FLAVOR"
OVH_SSH_KEY_NAME="SSH"
OVH_SECURITY_GROUP="SEC_GROUP"
OVH_NETWORK_ID="NETWORK"
OVH_SSH_USER="USER"

# Object Storage
# WARNING: Fill in OVH_S3_ACCESS_KEY and OVH_S3_SECRET_KEY in config.env — never commit real credentials
OVH_STATE_BUCKET="YOUR_BUCKET_HERE"
OVH_S3_ENDPOINT="YOUR_ENDPOINT_HERE"
OVH_S3_ACCESS_KEY="YOUR_ACCESS_KEY_HERE"
OVH_S3_SECRET_KEY="YOUR_SECRET_KEY_HERE"
